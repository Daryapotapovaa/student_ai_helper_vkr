{
	"name": "student-ai-helper",
	"displayName": "Student AI Helper",
	"description": "Инструмент умного автодополнения кода с педагогическими подсказками для учебных проектов на базе LSP",
	"author": "Potapova D.M.",
	"license": "MIT",
	"version": "1.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/your-username/student-ai-helper"
	},
	"publisher": "potapova-dm",
	"categories": [
		"Programming Languages",
		"Education",
		"Linters"
	],
	"keywords": [
		"python",
		"ai",
		"lsp",
		"education",
		"code completion",
		"student"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"activationEvents": [
		"onLanguage:python"
	],
	"main": "./client/out/extension",
	"contributes": {
		"commands": [
			{
				"command": "student-ai.insertComment",
				"title": "Student AI: Insert Help"
			}
		],
		"configuration": {
			"type": "object",
			"title": "Student AI Helper",
			"properties": {
				"studentAiHelper.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 1,
					"description": "Максимальное количество проблем, отображаемых сервером."
				},
				"studentAiHelper.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Трассировка коммуникации между VS Code и языковым сервером."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"lint": "eslint",
		"postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
		"test": "sh ./scripts/e2e.sh"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"eslint": "^9.13.0",
		"mocha": "^10.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}
